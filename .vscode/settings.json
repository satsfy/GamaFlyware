{
    "restoreTerminals.terminals": [
        {
            "splitTerminals": [
                {
                    "name": "PX4 SITL",
                    "commands": [
                        "source .bashrc; ./run_px4_sitl.sh default"
                    ]
                },
            ]
        },
        {
            "splitTerminals": [
                {
                    "name": "MAVROS Node",
                    "commands": [
                        "ros2 run mavros mavros_node --ros-args -p fcu_url:=udp://@127.0.0.1:14580"
                    ]
                },
            ]
        },
        {
            "splitTerminals": [
                {
                    "name": "Image Bridge",
                    "commands": [
                        "cd ws; source install/setup.bash; ros2 run ros_gz_image image_bridge /camera"
                    ]
                },
            ]
        },
        {
            "splitTerminals": [
                {
                    "name": "ORB_SLAM3 Webcam",
                    "commands": [
                        "cd ORB_SLAM3_files/ORB_SLAM3/webcam; ./run.sh"
                    ]
                },
            ]
        },
        {
            "splitTerminals": [
                {
                    "name": "QGroundControl",
                    "commands": [
                        "su qgcuser; ./QGroundControl.AppImage"
                    ]
                }
            ]
        },
        {
            "splitTerminals": [
                {
                    "name": "Mission Triangle",
                    "commands": [
                        "cd ws; source install/setup.bash; colcon build --packages-select mission; ros2 run mission triangle"
                    ]
                },
            ]
        },
    ]
    
    
    
    "git.ignoreLimitWarning": true,
    "python.autoComplete.extraPaths": [
        "/sitl/ws/install/px4_msgs/local/lib/python3.10/site-packages",
        "/opt/ros/humble/lib/python3.10/site-packages",
        "/opt/ros/humble/share/rclpy",
        "/opt/ros/humble/share/sensor_msgs",
        "/sitl/ws/install/px4_msgs/local/lib/python3.10/dist-packages",
        "/sitl/ws/install/px4_ros_com/lib/python3.10/site-packages",
        "/sitl/ws/install/your_custom_package/lib/python3.10/site-packages",
        "/opt/ros/humble/lib/python3.10/dist-packages",
        // "/sitl/ws/stubs"
        "/opt/ros/humble/local/lib/python3.10/dist-packages",
    ],
    "python.analysis.extraPaths": [
        "/sitl/ws/install/px4_msgs/local/lib/python3.10/dist-packages",
        "/sitl/ws/install/px4_ros_com/lib/python3.10/site-packages",
        "/sitl/ws/install/your_custom_package/lib/python3.10/site-packages",
        "/opt/ros/humble/lib/python3.10/dist-packages",
        "/sitl/ws/install/px4_msgs/local/lib/python3.10/site-packages",
        "/sitl/ws/install/px4_ros_com/lib/python3.10/site-packages",
        "/sitl/ws/install/your_custom_package/lib/python3.10/site-packages",
        "/opt/ros/humble/lib/python3.10/site-packages",
        "/opt/ros/humble/share/rclpy",
        "/opt/ros/humble/share/sensor_msgs",
        "/opt/ros/humble/local/lib/python3.10/dist-packages",
    ],
    "python.analysis.useLibraryCodeForTypes": true,
    "python.analysis.autoSearchPaths": true,
    "ros.distro": "humble",
    "git.ignoredRepositories": [
        "/sitl/PX4_Autopilot",
        "./ws/src/px4_msgs",
        "./ws/src/px4_ros_com",
    ],
    "python.formatting.provider": "black",
    "python.formatting.blackArgs": [
        "--line-length",
        "88"
    ],
    "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
